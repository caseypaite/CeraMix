# Copy to .env and adjust as needed.

# Override the Python interpreter the Tauri shell spawns for the backend.
# CERAMIX_PYTHON=python3

# Override the model weight cache directory (defaults to the OS app-data dir).
# CERAMIX_MODEL_DIR=

# Force a specific ONNX execution provider (otherwise auto-detected w/ CPU fallback).
# CERAMIX_ONNX_PROVIDER=CPUExecutionProvider
